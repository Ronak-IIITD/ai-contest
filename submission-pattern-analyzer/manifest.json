{
  "manifest_version": 3,
  "name": "Submission Pattern Analyzer",
  "description": "AI-powered cheating detection overlay for competitive programming contests. Real-time risk scoring for Codeforces & LeetCode.",
  "version": "1.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "128x128": "icons/icon128.png"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://leetcode.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Submission Pattern Analyzer",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "settings/settings.html",
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/contest/*/standings*"
      ],
      "js": [
        "content-scripts/codeforces-overlay.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://leetcode.com/contest/*/ranking*"
      ],
      "js": [
        "content-scripts/leetcode-overlay.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
